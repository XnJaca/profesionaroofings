---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { services } from '../../data/services';
import { site } from '../../data/site';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const otherServices = services.filter((s) => s.slug !== service.slug).slice(0, 4);
---

<Layout
  title={`${service.name} — Professional Construction LLC`}
  description={service.summary}
>
  <!-- Service hero -->
  <section class="service-hero">
    <Image
      src={service.cover}
      alt={service.coverAlt}
      class="service-hero-bg"
      widths={[768, 1280, 1600, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="service-hero-overlay"></div>

    <div class="container service-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#services">Services</a>
        <span aria-hidden="true">/</span>
        <span class="current">{service.shortName}</span>
      </nav>
      <h1>{service.name}</h1>
      <p class="tagline">{service.tagline}</p>
      <div class="hero-cta">
        <a href="/#contact" class="btn btn-accent">Get a Free Estimate →</a>
        <a href={`tel:${site.phoneRaw}`} class="btn btn-outline">Call {site.phone}</a>
      </div>
    </div>
  </section>

  <!-- Overview + features -->
  <section class="overview">
    <div class="container overview-grid">
      <div class="overview-text">
        <span class="eyebrow">Service overview</span>
        <h2 class="section-title">{service.summary}</h2>
        {service.description.map((p) => <p>{p}</p>)}
      </div>
      <aside class="overview-features">
        <h3>What&rsquo;s included</h3>
        <ul>
          {
            service.features.map((feature) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{feature}</span>
              </li>
            ))
          }
        </ul>
        <a href="/#contact" class="btn btn-primary feature-cta">Request estimate</a>
      </aside>
    </div>
  </section>

  <!-- Gallery -->
  <section class="service-gallery">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Project gallery</span>
        <h2 class="section-title">Recent {service.shortName.toLowerCase()} projects</h2>
        <p class="section-lead">
          Click any image to view it full-size. All photos are from real jobs completed by our
          team across the DMV.
        </p>
      </header>
      <Gallery images={service.gallery} />
    </div>
  </section>

  <!-- Related services -->
  <section class="related">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">More services</span>
        <h2 class="section-title">Explore other ways we can help.</h2>
      </header>
      <ul class="related-grid">
        {
          otherServices.map((s) => (
            <li>
              <a href={`/services/${s.slug}/`} class="related-card">
                <span class="related-image">
                  <Image
                    src={s.cover}
                    alt={s.coverAlt}
                    widths={[300, 500, 700]}
                    sizes="(min-width: 900px) 25vw, (min-width: 600px) 50vw, 100vw"
                  />
                </span>
                <span class="related-body">
                  <strong>{s.shortName}</strong>
                  <em>{s.tagline}</em>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <ContactCTA />
</Layout>

<style>
  .service-hero {
    position: relative;
    color: #fff;
    padding: 6rem 0 4.5rem;
    overflow: hidden;
    isolation: isolate;
  }

  .service-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .service-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 23, 51, 0.92) 0%,
      rgba(18, 37, 73, 0.72) 60%,
      rgba(30, 58, 110, 0.55) 100%
    );
    z-index: -1;
  }

  .service-hero-inner {
    max-width: 820px;
  }

  .breadcrumb {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent-soft);
  }

  .breadcrumb .current {
    color: var(--color-accent-soft);
  }

  .service-hero h1 {
    font-size: clamp(2.2rem, 4.6vw, 3.6rem);
    color: #fff;
    line-height: 1.08;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.2rem;
  }

  .hero-cta {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .overview {
    padding: 6rem 0;
    background: var(--color-bg);
  }

  .overview-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .overview-text .section-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.25;
    margin-bottom: 1.5rem;
  }

  .overview-text p {
    font-size: 1.05rem;
    color: var(--color-text-soft);
    line-height: 1.75;
    margin-bottom: 1.1rem;
  }

  .overview-features {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.8rem;
    position: sticky;
    top: 90px;
  }

  .overview-features h3 {
    font-size: 1.1rem;
    margin-bottom: 1.3rem;
  }

  .overview-features ul {
    list-style: none;
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.8rem;
  }

  .overview-features li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    align-items: flex-start;
    font-size: 0.96rem;
    color: var(--color-text-soft);
    line-height: 1.5;
  }

  .overview-features svg {
    width: 18px;
    height: 18px;
    color: var(--color-accent);
    margin-top: 3px;
    flex-shrink: 0;
  }

  .feature-cta {
    width: 100%;
  }

  .service-gallery {
    padding: 5rem 0;
    background: var(--color-bg-alt);
  }

  .related {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .related-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .related-card {
    display: block;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
  }

  .related-image {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .related-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .related-card:hover .related-image :global(img) {
    transform: scale(1.05);
  }

  .related-body {
    padding: 1.1rem 1.2rem 1.3rem;
    display: block;
  }

  .related-body strong {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-text);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .related-body em {
    display: block;
    font-style: normal;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .overview-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .overview-features {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
