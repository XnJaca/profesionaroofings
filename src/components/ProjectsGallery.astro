---
import { Image } from 'astro:assets';
import { services } from '../data/services';

// Pick one cover image from each of 6 featured services for the gallery
const featuredSlugs = [
  'asphalt-shingles',
  'siding',
  'kitchen-remodeling',
  'tpo-roofing',
  'bathroom-remodeling',
  'decks-porches',
];

const featured = featuredSlugs
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<section class="projects" id="projects">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">Recent work</span>
      <h2 class="section-title">Projects we&rsquo;re <span class="text-accent">proud of</span>.</h2>
      <p class="section-lead">
        A small selection of completed jobs across Maryland, Virginia, and DC. Visit any service
        page to see the full gallery.
      </p>
    </header>

    <ul class="grid">
      {
        featured.map((service) => (
          <li class="tile">
            <a href={`/services/${service.slug}/`}>
              <Image
                src={service.cover}
                alt={service.coverAlt}
                widths={[400, 600, 800, 1200]}
                sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              />
              <div class="tile-info">
                <small>{service.shortName}</small>
                <h4>{service.tagline}</h4>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .projects {
    background: var(--color-bg-alt);
    padding: 6rem 0;
  }

  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .tile {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-border);
  }

  .tile a {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .tile :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .tile a::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 23, 51, 0.86) 0%, transparent 55%);
    transition: opacity 0.3s;
  }

  .tile:hover :global(img) {
    transform: scale(1.05);
  }

  .tile-info {
    position: absolute;
    bottom: 1.4rem;
    left: 1.4rem;
    right: 1.4rem;
    color: #fff;
    z-index: 1;
  }

  .tile-info small {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent-soft);
  }

  .tile-info h4 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    margin-top: 0.35rem;
    color: #fff;
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
