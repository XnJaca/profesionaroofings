---
import { site } from '../data/site';
---

<div class="topbar">
  <div class="container topbar-inner">
    <ul class="topbar-licenses" aria-label="Licenses">
      {
        site.licenses.map((l) => (
          <li class="lic">
            <span class="lic-label">{l.label}</span>
            <span class="lic-num">
              {l.jurisdiction ? `${l.jurisdiction} – ` : ''}
              {l.number}
            </span>
          </li>
        ))
      }
    </ul>
    <div class="topbar-contact">
      <a href={`tel:${site.phoneRaw}`}>📞 {site.phone}</a>
    </div>
  </div>
</div>

<header class="nav" id="site-header">
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label={`${site.name} home`}>
      <img
        src="/logo.png"
        alt={`${site.name} logo`}
        class="logo-img"
        width="220"
        height="146"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="nav-links" id="primary-nav" aria-label="Primary">
      <a href="/">Home</a>
      <a href="/#services">Services</a>
      <a href="/#about">About</a>
      <a href="/#projects">Projects</a>
      <a href="/#contact">Contact</a>
      <a href="/#contact" class="btn btn-accent nav-cta">Free Estimate</a>
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .topbar {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.82rem;
    padding: 0.55rem 0;
    letter-spacing: 0.02em;
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .topbar-licenses {
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0 1.1rem;
    margin: 0;
    padding: 0;
  }

  .topbar-licenses .lic {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    position: relative;
    padding-left: 0.95rem;
  }

  .topbar-licenses .lic::before {
    content: '';
    position: absolute;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-soft);
    box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.2);
  }

  .lic-label {
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    font-weight: 500;
  }

  .lic-num {
    font-family: var(--font-heading);
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.03em;
  }

  .topbar-contact {
    margin-left: auto;
    display: flex;
    gap: 1.2rem;
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .topbar-contact a {
    transition: color 0.2s;
  }

  .topbar-contact a:hover {
    color: var(--color-accent-soft);
  }

  .nav {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    color: var(--color-primary);
    height: 72px;
    width: 220px;
    overflow: hidden;
  }

  .logo-img {
    height: 72px;
    width: 100%;
    object-fit: contain;
    display: block;
    transform: scale(2.1);
    transform-origin: center center;
  }

  @media (max-width: 540px) {
    .logo {
      height: 58px;
      width: 180px;
    }
    .logo-img {
      height: 58px;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-text-soft);
    position: relative;
    transition: color 0.2s;
  }

  .nav-links a:not(.nav-cta):hover {
    color: var(--color-primary);
  }

  .nav-links a:not(.nav-cta)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 0;
    background: var(--color-accent);
    transition: width 0.25s ease;
  }

  .nav-links a:not(.nav-cta):hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.65rem 1.2rem;
    font-size: 0.82rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
  }

  .nav-toggle span {
    width: 26px;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (max-width: 900px) {
    .topbar-inner {
      justify-content: center;
      text-align: center;
    }

    .topbar-licenses {
      justify-content: center;
      gap: 0.15rem 0.9rem;
      width: 100%;
    }

    .topbar-contact {
      margin-left: 0;
      width: 100%;
      justify-content: center;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #fff;
      padding: 1rem 1.25rem 1.25rem;
      border-bottom: 1px solid var(--color-border);
      gap: 1rem;
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .nav-links.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-links a {
      padding: 0.4rem 0;
    }

    .nav-cta {
      align-self: flex-start;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
