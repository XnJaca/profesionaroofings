---
import { site } from '../data/site';
---

<div class="topbar">
  <div class="container topbar-inner">
    <span class="topbar-badge">{site.license} · Licensed &amp; Insured</span>
    <span class="topbar-sep">·</span>
    <span class="topbar-area">Serving {site.serviceArea}</span>
    <div class="topbar-contact">
      <a href={`tel:${site.phoneRaw}`}>📞 {site.phone}</a>
    </div>
  </div>
</div>

<header class="nav" id="site-header">
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label={`${site.name} home`}>
      <img
        src="/logo.jpg"
        alt={`${site.name} logo`}
        class="logo-img"
        width="220"
        height="146"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="nav-links" id="primary-nav" aria-label="Primary">
      <a href="/">Home</a>
      <a href="/#services">Services</a>
      <a href="/#about">About</a>
      <a href="/#projects">Projects</a>
      <a href="/#contact">Contact</a>
      <a href="/#contact" class="btn btn-accent nav-cta">Free Estimate</a>
    </nav>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .topbar {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.82rem;
    padding: 0.55rem 0;
    letter-spacing: 0.02em;
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .topbar-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .topbar-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-soft);
  }

  .topbar-sep {
    opacity: 0.4;
  }

  .topbar-area {
    color: rgba(255, 255, 255, 0.7);
  }

  .topbar-contact {
    margin-left: auto;
    display: flex;
    gap: 1.2rem;
  }

  .topbar-contact a {
    transition: color 0.2s;
  }

  .topbar-contact a:hover {
    color: var(--color-accent-soft);
  }

  .nav {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    color: var(--color-primary);
  }

  .logo-img {
    height: 64px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 540px) {
    .logo-img {
      height: 52px;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-text-soft);
    position: relative;
    transition: color 0.2s;
  }

  .nav-links a:not(.nav-cta):hover {
    color: var(--color-primary);
  }

  .nav-links a:not(.nav-cta)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 0;
    background: var(--color-accent);
    transition: width 0.25s ease;
  }

  .nav-links a:not(.nav-cta):hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 0.65rem 1.2rem;
    font-size: 0.82rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 6px;
  }

  .nav-toggle span {
    width: 26px;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (max-width: 900px) {
    .topbar-sep,
    .topbar-area {
      display: none;
    }

    .topbar-contact {
      margin-left: auto;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #fff;
      padding: 1rem 1.25rem 1.25rem;
      border-bottom: 1px solid var(--color-border);
      gap: 1rem;
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .nav-links.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-links a {
      padding: 0.4rem 0;
    }

    .nav-cta {
      align-self: flex-start;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
