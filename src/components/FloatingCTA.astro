---
import { site } from '../data/site';
---

<div class="fab-wrap" aria-hidden="false">
  <a
    class="fab whatsapp"
    href={site.whatsapp}
    target="_blank"
    rel="noopener"
    aria-label="Message us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.6.2-1.2.2-1.4-.1-.2-.3-.2-.5-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 4.9L2 22l5.3-1.4C8.7 21.5 10.3 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z" />
    </svg>
  </a>
  <a class="fab phone" href={`tel:${site.phoneRaw}`} aria-label={`Call ${site.phone}`}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13 1.05.37 2.07.72 3.04a2 2 0 01-.45 2.11L8.09 10.2a16 16 0 006 6l1.34-1.29a2 2 0 012.11-.45c.97.35 2 .59 3.04.72A2 2 0 0122 16.92z" />
    </svg>
  </a>
</div>

<style>
  .fab-wrap {
    position: fixed;
    right: 1.2rem;
    bottom: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    z-index: 80;
  }

  .fab {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: #fff;
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .fab:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .fab svg {
    width: 26px;
    height: 26px;
  }

  .whatsapp {
    background: #25d366;
  }

  .phone {
    background: var(--color-accent);
  }

  @media (max-width: 540px) {
    .fab-wrap {
      right: 0.9rem;
      bottom: 0.9rem;
    }
    .fab {
      width: 48px;
      height: 48px;
    }
    .fab svg {
      width: 22px;
      height: 22px;
    }
  }
</style>
